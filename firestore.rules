rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isLoggedIn() {
      return request.auth != null;
    }

    function isTestAccount() {
      return request.auth != null
        && request.auth.token.email == 'test@example.com';
    }

    function hasReservedEmail(playerId) {
      return !('normalized_email' in request.resource.data)
        || request.resource.data.normalized_email == null
        || existsAfter(/databases/$(database)/documents/player_contacts/$(('email_' + request.resource.data.normalized_email)))
          && getAfter(/databases/$(database)/documents/player_contacts/$(('email_' + request.resource.data.normalized_email))).data.player_id == playerId;
    }

    function hasReservedPhone(playerId) {
      return !('normalized_phone_number' in request.resource.data)
        || request.resource.data.normalized_phone_number == null
        || existsAfter(/databases/$(database)/documents/player_contacts/$(('phone_' + request.resource.data.normalized_phone_number)))
          && getAfter(/databases/$(database)/documents/player_contacts/$(('phone_' + request.resource.data.normalized_phone_number))).data.player_id == playerId;
    }

    // Players Collection
    match /players/{playerId} {
      allow read: if true;
      
      allow create: if isLoggedIn()
        && request.resource.data.owner_id == request.auth.uid
        && request.resource.data.id == playerId
        && request.resource.data.total_score == 0
        && request.resource.data.player_name is string
        && request.resource.data.player_name.size() > 0
        && request.resource.data.player_name.size() <= 100
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() <= 100
        && (!('email' in request.resource.data) || request.resource.data.email == null || (request.resource.data.email is string && request.resource.data.email.size() <= 100))
        && (!('phone_number' in request.resource.data) || request.resource.data.phone_number == null || (request.resource.data.phone_number is string && request.resource.data.phone_number.size() <= 30))
        && (!('normalized_email' in request.resource.data) || request.resource.data.normalized_email == null || (request.resource.data.normalized_email is string && request.resource.data.normalized_email.size() <= 100))
        && (!('normalized_phone_number' in request.resource.data) || request.resource.data.normalized_phone_number == null || (request.resource.data.normalized_phone_number is string && request.resource.data.normalized_phone_number.size() <= 30))
        && (!('status' in request.resource.data) || request.resource.data.status == null || (request.resource.data.status is string && request.resource.data.status.size() <= 200))
        && (!('avatar_image_location' in request.resource.data) || request.resource.data.avatar_image_location == null || (request.resource.data.avatar_image_location is string && request.resource.data.avatar_image_location.size() <= 500))
        && hasReservedEmail(playerId)
        && hasReservedPhone(playerId);

      allow update: if isLoggedIn() && (
        // Case 1: Owner updates their profile fields. Must not change key identifier fields.
        (
          resource.data.owner_id == request.auth.uid
          && request.resource.data.owner_id == resource.data.owner_id
          && request.resource.data.id == resource.data.id
          && request.resource.data.player_name is string
          && request.resource.data.player_name.size() > 0
          && request.resource.data.player_name.size() <= 100
          && request.resource.data.nickname is string
          && request.resource.data.nickname.size() <= 100
          && (request.resource.data.total_score is int || request.resource.data.total_score is float)
          && request.resource.data.total_score >= 0
          && (!('email' in request.resource.data) || request.resource.data.email == null || (request.resource.data.email is string && request.resource.data.email.size() <= 100))
          && (!('phone_number' in request.resource.data) || request.resource.data.phone_number == null || (request.resource.data.phone_number is string && request.resource.data.phone_number.size() <= 30))
          && (!('normalized_email' in request.resource.data) || request.resource.data.normalized_email == null || (request.resource.data.normalized_email is string && request.resource.data.normalized_email.size() <= 100))
          && (!('normalized_phone_number' in request.resource.data) || request.resource.data.normalized_phone_number == null || (request.resource.data.normalized_phone_number is string && request.resource.data.normalized_phone_number.size() <= 30))
          && (!('status' in request.resource.data) || request.resource.data.status == null || (request.resource.data.status is string && request.resource.data.status.size() <= 200))
          && (!('avatar_image_location' in request.resource.data) || request.resource.data.avatar_image_location == null || (request.resource.data.avatar_image_location is string && request.resource.data.avatar_image_location.size() <= 500))
        )
        // Case 2: Peer user or game host updates only the total_score field after a game.
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['total_score'])
          && (request.resource.data.total_score is int || request.resource.data.total_score is float)
          && request.resource.data.total_score >= 0
        )
        // Case 3: A verified Firebase Auth contact claims an unclaimed player.
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['claimed_by_uid'])
          && resource.data.claimed_by_uid == null
          && request.resource.data.claimed_by_uid == request.auth.uid
          && (
            (
              request.auth.token.email_verified == true
              && resource.data.normalized_email == request.auth.token.email
            )
            || (
              request.auth.token.phone_number != null
              && resource.data.normalized_phone_number == request.auth.token.phone_number
            )
          )
        )
      );

      allow delete: if isLoggedIn() && resource.data.owner_id == request.auth.uid;
    }

    // Canonical contact reservations. The deterministic document ID is the
    // uniqueness boundary for normalized emails and phone numbers.
    match /player_contacts/{contactId} {
      allow read: if true;

      allow create: if (
          isLoggedIn()
          && request.resource.data.player_id is string
          && request.resource.data.created_by_uid == request.auth.uid
          && (
            (
              request.resource.data.kind == 'email'
              && request.resource.data.normalized_value is string
              && contactId == 'email_' + request.resource.data.normalized_value
            )
            || (
              request.resource.data.kind == 'phone'
              && request.resource.data.normalized_value is string
              && contactId == 'phone_' + request.resource.data.normalized_value
            )
          )
        )
        || isTestAccount();

      allow update, delete: if isTestAccount();
    }

    // Claim requests are owned by the trusted backend only. Cloud Functions
    // uses the Admin SDK and bypasses client rules.
    match /claim_requests/{claimRequestId} {
      allow read, write: if isTestAccount();
    }

    // Friends Collection
    match /friends/{friendDocId} {
      allow read: if true;
      
      allow create, update: if isLoggedIn()
        && (request.resource.data.player_id == request.auth.uid || request.resource.data.friend_id == request.auth.uid)
        && request.resource.data.player_id is string
        && request.resource.data.player_id.size() > 0
        && request.resource.data.player_id.size() <= 100
        && request.resource.data.friend_id is string
        && request.resource.data.friend_id.size() > 0
        && request.resource.data.friend_id.size() <= 100
        && friendDocId == request.resource.data.player_id + '_' + request.resource.data.friend_id;

      allow delete: if isLoggedIn() && (resource.data.player_id == request.auth.uid || resource.data.friend_id == request.auth.uid);
    }

    // Courses Collection
    match /courses/{courseId} {
      allow read: if true;
      
      allow create, update: if request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.number_of_holes is int
        && request.resource.data.number_of_holes >= 1
        && request.resource.data.number_of_holes <= 36
        && request.resource.data.par_strokes is map;

      allow delete: if false;
    }

    // Games Collection
    match /games/{gameId} {
      allow create, read, update: if true;

      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.creator_id || isTestAccount());
    }

    // Player Game Info Collection
    match /player_game_info/{infoId} {
      allow read: if isLoggedIn();

      allow create, update: if isLoggedIn()
        && (
          request.resource.data.player_id == request.auth.uid
          || get(/databases/$(database)/documents/games/$(request.resource.data.game_id)).data.creator_id == request.auth.uid
        )
        && request.resource.data.game_id is string
        && request.resource.data.player_id is string
        && request.resource.data.place is string
        && request.resource.data.place.size() <= 50
        && request.resource.data.play_order_position is int
        && request.resource.data.scores is list
        && request.resource.data.total_score is int
        && infoId == request.resource.data.game_id + '_' + request.resource.data.player_id;

      allow delete: if isLoggedIn()
        && (
          resource.data.player_id == request.auth.uid
          || get(/databases/$(database)/documents/games/$(resource.data.game_id)).data.creator_id == request.auth.uid
        );
    }
  }
}
